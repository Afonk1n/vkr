FROM node:18-bullseye-slim

WORKDIR /app

# Не ставить CI=true: в dev это ломает привычный режим CRA (оверлей/интерактив) и мешает отладке.
ENV CI=false
ENV PORT=3000

COPY package.json package-lock.json ./

# Use npm install (not ci) to be tolerant to lock drift during active development.
RUN npm install

COPY . .

EXPOSE 3000

CMD ["npm", "start"]
