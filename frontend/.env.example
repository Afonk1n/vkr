REACT_APP_API_URL=http://localhost:8080/api

# Set to true only if you explicitly run frontend without backend
REACT_APP_USE_MOCK=false

# Если запускаешь `npm start` на хосте, а правки «не доезжают» в браузер — можно включить polling
# (в docker-compose для сервиса frontend это уже задано через environment)
# CHOKIDAR_USEPOLLING=true
# WATCHPACK_POLLING=true

